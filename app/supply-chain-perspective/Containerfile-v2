# syntax=docker/dockerfile:1
# ============================================================
# Containerfile-v2 — merged from Containerfile + Dockerfile
#
# Replaces the minimal Dockerfile (ADD + two-stage build) with the
# production-oriented Containerfile behavior: linux/amd64 targets,
# custom nginx.conf (port 9001 / TLS mount paths), OpenShift SCC-friendly
# permissions, and CYPRESS_INSTALL_BINARY=0 for lean installs.
#
# Build on macOS with Podman targeting linux/amd64:
#   podman build --platform linux/amd64 -t my-plugin:latest .
#
# OpenShift 4.21 console plugin — SSL requirements:
#   The OpenShift console proxy REQUIRES the plugin service to
#   speak HTTPS on port 9001. Certificates are NOT baked into
#   the image. Instead, OpenShift's service-ca controller injects
#   a signed TLS secret at deploy time, which the pod mounts at:
#
#     /var/serving-cert/tls.crt   (certificate)
#     /var/serving-cert/tls.key   (private key)
#
#   To enable this, annotate your Service with:
#     service.beta.openshift.io/serving-cert-secret-name: <plugin-name>-tls
#   Then mount that secret into the pod at /var/serving-cert (readOnly).
#
# OpenShift 4.21 SCC (restricted-v2) constraints satisfied:
#   - Runs as non-root numeric UID (1001), overridden to arbitrary UID at runtime.
#   - All runtime-writable paths owned by GID 0, chmod g=u.
#   - No capabilities required (listens on 9001, not a privileged port).
#   - No secrets baked into the image layer.
# ============================================================

# ── Stage 1: build ──────────────────────────────────────────
FROM --platform=linux/amd64 registry.access.redhat.com/ubi9/nodejs-22:latest AS build

USER root
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0

RUN npm i -g corepack && corepack enable

WORKDIR /usr/src/app

COPY --chown=root:root . .

# Inlined into the JS bundle at webpack build time (browser fetch base URL).
# Override at image build: podman build --build-arg SUPPLY_CHAIN_API_BASE_URL=https://api.example.com ...
ARG SUPPLY_CHAIN_API_BASE_URL=
ENV SUPPLY_CHAIN_API_BASE_URL=${SUPPLY_CHAIN_API_BASE_URL}

# Cypress is only used for local/CI e2e tests; its postinstall downloads a large
# browser binary that often fails or is unnecessary inside the image build.
ENV CYPRESS_INSTALL_BINARY=0

RUN yarn install --immutable && yarn build

# ── Stage 2: runtime ────────────────────────────────────────
FROM --platform=linux/amd64 registry.access.redhat.com/ubi9/nginx-120:latest

# ubi9/nginx-120 sets a non-root user — switch to root for setup.
USER root

COPY --from=build /usr/src/app/dist /usr/share/nginx/html

COPY --chown=0:0 nginx.conf /etc/nginx/nginx.conf

# mkdir -p all paths first — ubi9/nginx-120 does not pre-create
# /var/cache/nginx, /var/log/nginx, or /var/serving-cert.
RUN mkdir -p /var/serving-cert \
             /var/cache/nginx \
             /var/log/nginx \
             /var/run \
    && chown -R 0:0 /usr/share/nginx/html \
                    /var/cache/nginx \
                    /var/log/nginx \
                    /var/run \
                    /var/serving-cert \
    && chmod -R g=u /usr/share/nginx/html \
                    /var/cache/nginx \
                    /var/log/nginx \
                    /var/run \
                    /var/serving-cert \
    && chmod 644 /etc/nginx/nginx.conf

# Drop back to non-root for runtime.
# OpenShift will override with an arbitrary UID that is a member of GID 0.
USER 1001

EXPOSE 9001

ENTRYPOINT ["nginx", "-g", "daemon off;"]
